# ── SERVER ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001

# ── DATABASE ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://seewhy:dev_password@localhost:5432/seewhy_live

# ── REDIS ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AUTH (RS256 asymmetric JWT) ──────────────────────────────────
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem

# ── ENCRYPTION (AES-256-GCM for stream keys) ─────────────────────
ENCRYPTION_SECRET=exactly32characterslongplease___

# ── VDO.NINJA ────────────────────────────────────────────────────
VDO_NINJA_API_KEY=your_vdo_ninja_api_key
VDO_NINJA_SALT=64_char_random_hex_string_here
MEDIAMTX_BASE=https://mesh.seewhylive.com

# ── STRIPE ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PLATFORM_ACCOUNT_ID=acct_...
STRIPE_PRICE_BRONZE=price_...
STRIPE_PRICE_SILVER=price_...
STRIPE_PRICE_GOLD=price_...

# ── ANTHROPIC (Aura AI) ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── EMAIL ────────────────────────────────────────────────────────
SMTP_HOST=smtp.postmarkapp.com
SMTP_PORT=587
SMTP_USER=your_postmark_api_token
SMTP_PASS=your_postmark_api_token
EMAIL_FROM=hello@seewhylive.com

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# ── SECURITY ─────────────────────────────────────────────────────
COOKIE_SECRET=random_64_char_hex
HELMET_CSP=true
