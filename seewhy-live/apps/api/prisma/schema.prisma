// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole     { USER CREATOR ADMIN }
enum StageStatus  { UPCOMING LIVE ENDED }
enum GuestRole    { HOST GUEST VIEWER }
enum Platform     { YOUTUBE TWITCH TIKTOK FACEBOOK CUSTOM OBS_WHIP }
enum TxType       { SUPERCHAT SUBSCRIPTION TIP PRODUCT_SALE }
enum TxStatus     { PENDING COMPLETED REFUNDED }
enum SubTier      { BRONZE SILVER GOLD }
enum SubStatus    { ACTIVE CANCELLED PAST_DUE }
enum ProductType  { DIGITAL PHYSICAL }
enum MsgType      { CHAT SUPERCHAT SYSTEM }
enum ChatPlatform { SEEWHY YOUTUBE TWITCH TIKTOK FACEBOOK }

model User {
  id               String        @id @default(cuid())
  clerkId          String?       @unique
  displayName      String
  username         String        @unique
  email            String        @unique
  passwordHash     String?
  role             UserRole      @default(USER)
  avatarUrl        String?
  bio              String?
  isVerified       Boolean       @default(false)
  stripeConnectId  String?
  stripeCustomerId String?
  chargesEnabled   Boolean       @default(false)
  payoutsEnabled   Boolean       @default(false)
  emailVerified    Boolean       @default(false)
  emailVerifyToken String?
  resetToken       String?
  resetTokenExp    DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  stages           Stage[]       @relation("CreatorStages")
  stageGuests      StageGuest[]
  streamKeys       StreamKey[]
  txFrom           Transaction[] @relation("TxFrom")
  txTo             Transaction[] @relation("TxTo")
  subscriptionsAs  Subscription[] @relation("Subscriber")
  subscribersOf    Subscription[] @relation("Creator")
  products         Product[]
  chatMessages     ChatMessage[]
  refreshTokens    RefreshToken[]
  follows          Follow[]      @relation("Follower")
  followers        Follow[]      @relation("Followed")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  family    String   // rotation family — entire family invalidated on theft
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields:[userId], references:[id], onDelete:Cascade)
}

model Follow {
  id         String   @id @default(cuid())
  followerId String
  followedId String
  createdAt  DateTime @default(now())
  follower   User     @relation("Follower", fields:[followerId], references:[id], onDelete:Cascade)
  followed   User     @relation("Followed", fields:[followedId], references:[id], onDelete:Cascade)
  @@unique([followerId, followedId])
}

model Stage {
  id           String      @id @default(cuid())
  title        String
  description  String?
  coverImageUrl String?
  creatorId    String
  status       StageStatus @default(UPCOMING)
  isPublic     Boolean     @default(true)
  defaultBitrate Int       @default(2500)
  useMeshcast  Boolean     @default(false)
  scheduledAt  DateTime?
  startedAt    DateTime?
  endedAt      DateTime?
  guestLimit   Int         @default(20)
  tags         String[]
  roomId       String?     // derived HMAC, cached after first call
  category     String?
  streamType   String?
  createdAt    DateTime    @default(now())

  creator      User        @relation("CreatorStages", fields:[creatorId], references:[id])
  guests       StageGuest[]
  streamKeys   StreamKey[]
  transactions Transaction[]
  chatMessages ChatMessage[]
  watchParty   WatchParty?
}

model StageGuest {
  id       String    @id @default(cuid())
  stageId  String
  userId   String
  role     GuestRole @default(VIEWER)
  joinedAt DateTime  @default(now())
  leftAt   DateTime?
  stage    Stage     @relation(fields:[stageId], references:[id], onDelete:Cascade)
  user     User      @relation(fields:[userId], references:[id], onDelete:Cascade)
  @@unique([stageId, userId])
}

model StreamKey {
  id           String   @id @default(cuid())
  userId       String
  stageId      String?
  platform     Platform
  label        String
  encryptedKey String              // AES-256-GCM ciphertext (base64)
  keyIv        String              // AES-256-GCM IV (base64)
  keyTag       String              // AES-256-GCM auth tag (base64)
  isActive     Boolean  @default(true)
  lastUsedAt   DateTime?
  createdAt    DateTime @default(now())
  user         User     @relation(fields:[userId], references:[id], onDelete:Cascade)
  stage        Stage?   @relation(fields:[stageId], references:[id])
}

model Transaction {
  id                   String   @id @default(cuid())
  fromUserId           String?
  toUserId             String
  stageId              String?
  type                 TxType
  grossAmount          Decimal  @db.Decimal(10,2)
  // ─── FEE ENFORCEMENT ─────────────────────────────────────────────────
  // IMMUTABLE: platformFee is ALWAYS grossAmount * 0.10
  // IMMUTABLE: creatorAmount is ALWAYS grossAmount * 0.90
  // These are stored computed values — never accept them from client input
  platformFee          Decimal  @db.Decimal(10,2)  // = grossAmount * 0.10
  creatorAmount        Decimal  @db.Decimal(10,2)  // = grossAmount * 0.90
  // ─────────────────────────────────────────────────────────────────────
  currency             String   @default("USD")
  status               TxStatus @default(PENDING)
  stripePaymentIntentId String?
  stripeFeeId          String?
  idempotencyKey       String?  @unique
  createdAt            DateTime @default(now())

  fromUser   User?    @relation("TxFrom", fields:[fromUserId], references:[id])
  toUser     User     @relation("TxTo", fields:[toUserId], references:[id])
  stage      Stage?   @relation(fields:[stageId], references:[id])
  feeRecord  FeeRecord?
}

// Append-only fee audit ledger — third enforcement layer
model FeeRecord {
  id             String      @id @default(cuid())
  transactionId  String      @unique
  grossAmount    Decimal     @db.Decimal(10,2)
  platformFee    Decimal     @db.Decimal(10,2)  // MUST equal transactionId.grossAmount * 0.10
  creatorAmount  Decimal     @db.Decimal(10,2)  // MUST equal transactionId.grossAmount * 0.90
  verifiedAt     DateTime    @default(now())
  transaction    Transaction @relation(fields:[transactionId], references:[id])
}

model Subscription {
  id                   String    @id @default(cuid())
  subscriberId         String
  creatorId            String
  tier                 SubTier
  amount               Decimal   @db.Decimal(10,2) // 1.00 | 5.00 | 15.00 — FIXED
  stripeSubscriptionId String?
  stripePriceId        String?
  status               SubStatus @default(ACTIVE)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())

  subscriber User @relation("Subscriber", fields:[subscriberId], references:[id])
  creator    User @relation("Creator", fields:[creatorId], references:[id])
  @@unique([subscriberId, creatorId, tier])
}

model Product {
  id          String      @id @default(cuid())
  creatorId   String
  title       String
  description String?
  imageUrl    String?
  price       Decimal     @db.Decimal(10,2)
  currency    String      @default("USD")
  type        ProductType
  isActive    Boolean     @default(true)
  inventory   Int?
  stripePriceId String?
  stripeProductId String?
  createdAt   DateTime    @default(now())
  creator     User        @relation(fields:[creatorId], references:[id])
}

model ChatMessage {
  id        String       @id @default(cuid())
  stageId   String
  userId    String?
  message   String
  type      MsgType      @default(CHAT)
  amount    Decimal?     @db.Decimal(10,2)
  platform  ChatPlatform @default(SEEWHY)
  createdAt DateTime     @default(now())
  stage     Stage        @relation(fields:[stageId], references:[id], onDelete:Cascade)
  user      User?        @relation(fields:[userId], references:[id])
}

model WatchParty {
  id          String   @id @default(cuid())
  stageId     String   @unique
  videoUrl    String
  currentTime Float    @default(0)
  isPaused    Boolean  @default(true)
  syncedAt    DateTime @default(now())
  stage       Stage    @relation(fields:[stageId], references:[id], onDelete:Cascade)
}
